<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.LernController">

    <top>
        <HBox spacing="10">
            <padding>
                <Insets bottom="10" left="15" right="15" top="15" />
            </padding>
            <Button onAction="#zurueck" text="Zurueck" />
            <Label fx:id="lblFortschritt" style="-fx-font-size: 14;" text="" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets bottom="15" left="30" right="30" top="15" />
            </padding>

            <Label fx:id="lblFrage" style="-fx-font-size: 20;" text="Frage" wrapText="true" />
            <Label fx:id="lblAntwort" style="-fx-font-size: 18; -fx-text-fill: #2060a0;" text="" wrapText="true" />

            <Button fx:id="btnZeigen" onAction="#antwortZeigen" text="Antwort zeigen" />

            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnRichtig" onAction="#richtig" prefWidth="120" style="-fx-base: #b6e2b6;" text="Richtig" />
                <Button fx:id="btnFalsch" onAction="#falsch" prefWidth="120" style="-fx-base: #e8b6b6;" text="Falsch" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
