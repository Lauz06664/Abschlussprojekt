<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="520" prefWidth="600" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.LernController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="10" left="15" right="15" top="15" />
            </padding>
            <Button onAction="#zurueck" styleClass="button-secondary" text="Zurück" />
            <Label fx:id="lblFortschritt" styleClass="subtitle" text="" />
        </HBox>
    </top>

    <center>
        <!-- StackPane mit festem Rand: der Abstand der weissen Karte zum Fensterrand bleibt immer gleich. -->
        <StackPane>
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Die Karte fuellt die Breite, waechst in der Hoehe aber nur so weit wie der Inhalt es braucht. -->
            <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="1000">

                <!-- Frage/Antwort scrollen, falls der Text zu lang fuer die Karte wird. -->
                <ScrollPane styleClass="card-scroll" fitToWidth="true" hbarPolicy="NEVER" maxHeight="250">
                    <content>
                        <VBox alignment="CENTER" spacing="20">
                            <Label fx:id="lblFrage" styleClass="frage-label" text="Frage" wrapText="true" textAlignment="CENTER" maxWidth="1000" />
                            <Label fx:id="lblAntwort" styleClass="antwort-label" text="" wrapText="true" textAlignment="CENTER" maxWidth="1000" />
                        </VBox>
                    </content>
                </ScrollPane>

                <Button fx:id="btnZeigen" onAction="#antwortZeigen" text="Antwort zeigen" />

                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnRichtig" onAction="#richtig" prefWidth="120" styleClass="button-richtig" text="Richtig" />
                    <Button fx:id="btnFalsch" onAction="#falsch" prefWidth="120" styleClass="button-falsch" text="Falsch" />
                </HBox>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
