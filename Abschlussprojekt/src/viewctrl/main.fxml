<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500" prefWidth="910" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.MainController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <Label styleClass="title" text="Lernkartei - Übersicht" />
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Neues Deck:" />
                <TextField fx:id="txtNeuesDeck" prefWidth="200" />
                <Button onAction="#neuesDeck" text="Deck anlegen" />
                <Button onAction="#neueKarte" text="Neue Karte" />
                <Button onAction="#lernenStarten" text="Lernen starten" />
                <Button onAction="#statistikAnzeigen" text="Statistik" />
                <Button onAction="#speichern" text="Speichern" />
            </HBox>
            <Label fx:id="lblInfo" styleClass="error-label" text="" />
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="section-label" text="Decks:" />
                <ListView fx:id="deckView" VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label styleClass="section-label" text="Karten im Deck:" />
                <ListView fx:id="kartenView" VBox.vgrow="ALWAYS" />
            </VBox>
        </HBox>
    </center>

</BorderPane>
